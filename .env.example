# .env — API keys for the research pipeline
# Copy this file to your project root as `.env` and fill in the values.
# This file is gitignored. Never commit secrets to the repo.
#
# All keys are optional — features degrade gracefully without them.
# Orchestrator loads this file at Stage 0 Step 1.5 via line-by-line parsing.
# Skills access keys via os.environ.get("KEY_NAME").

# Firecrawl — deep scrape of Papers with Code pages.
# v1.6 note: the weights URL validation path no longer uses Firecrawl
# (curl HEAD + range-GET fallback instead — see paper-finder D1/D2).
# Firecrawl remains optional for PwC deep scraping.
# Free 500 credits/month at https://firecrawl.dev
# Without it: paper finder uses PwC JSON API only (less detail);
#             dataset hunter Source 5 skips non-direct-download datasets.
FIRECRAWL_API_KEY=

# Roboflow Universe — public dataset exports
# Free at https://roboflow.com
# Without it: dataset hunter Source 2 (Roboflow) is skipped entirely.
ROBOFLOW_API_KEY=

# HuggingFace — access to gated/private datasets
# Get a token at https://huggingface.co/settings/tokens
# Without it: only public datasets are downloadable.
HF_TOKEN=
